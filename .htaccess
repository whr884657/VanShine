# VanShine URL Rewrite (Optional)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 禁止直接访问 config 目录
    RewriteRule ^config/ - [F,L]

    # 分享短链接：统一由 d/index.php 处理（token 解析与下载流）
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^d(/.*)?$ d/index.php [L,QSA]
</IfModule>

# 禁止目录浏览
Options -Indexes
