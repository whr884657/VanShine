# VanShine 本地储存对外直链 — Nginx 配置示例
# 将以下规则加入站点 server {} 块（站点根目录为 VanShine 项目根）

location ~ ^/([a-z])/([^/]+)$ {
    rewrite ^/([a-z])/([^/]+)$ /public-file.php?slug=$1&name=$2 last;
}

# 若 VanShine 部署在子目录（如 /van/），改为：
# location ~ ^/van/([a-z])/([^/]+)$ {
#     rewrite ^/van/([a-z])/([^/]+)$ /van/public-file.php?slug=$1&name=$2 last;
# }
